<UserControl x:Class="CocoroConsole.Controls.EmbeddingSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1100"
             d:DesignWidth="800">

        <UserControl.Resources>
                <Style x:Key="SettingLabelStyle"
                       TargetType="TextBlock">
                        <Setter Property="VerticalAlignment"
                                Value="Center"/>
                        <Setter Property="Margin"
                                Value="0,0,10,0"/>
                        <Setter Property="Width"
                                Value="150"/>
                </Style>
                <Style x:Key="SettingTextBoxStyle"
                       TargetType="TextBox">
                        <Setter Property="Foreground"
                                Value="#FF0078D7"/>
                        <Setter Property="Padding"
                                Value="2"/>
                        <Setter Property="BorderBrush"
                                Value="#CCCCCC"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                </Style>
                <Style x:Key="PresetButtonStyle"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="#4873CF"/>
                        <Setter Property="Foreground"
                                Value="WhiteSmoke"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Padding"
                                Value="10,5"/>
                </Style>
        </UserControl.Resources>

        <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                                <Grid Margin="0,0,20,0"
                                      HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox x:Name="MemorySetSelectComboBox"
                                                  Grid.Column="0"
                                                  Margin="0,5,10,5"
                                                  SelectionChanged="MemorySetSelectComboBox_SelectionChanged"
                                                  HorizontalAlignment="Stretch"/>

                                        <Button Grid.Column="1"
                                                Content="追加"
                                                Margin="0,5,0,5"
                                                Padding="10,5"
                                                Style="{StaticResource PresetButtonStyle}"
                                                Click="AddMemorySetButton_Click"/>

                                        <Button Grid.Column="2"
                                                Content="クローン"
                                                Margin="5,5,0,5"
                                                Padding="10,5"
                                                Style="{StaticResource PresetButtonStyle}"
                                                Click="CloneMemorySetButton_Click"/>

                                        <Button Grid.Column="3"
                                                Content="設定複製"
                                                Margin="5,5,0,5"
                                                Padding="10,5"
                                                Style="{StaticResource PresetButtonStyle}"
                                                Click="DuplicateMemorySetSettingsButton_Click"/>

                                        <Button Grid.Column="4"
                                                Content="削除"
                                                Margin="5,5,0,5"
                                                Padding="10,5"
                                                Style="{StaticResource DeleteButtonStyle}"
                                                Click="DeleteMemorySetButton_Click"/>
                                </Grid>

                                <Grid Margin="0,20,20,20">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="プリセット名:"
                                                   Style="{StaticResource SettingLabelStyle}"/>
                                        <TextBox x:Name="MemorySetDisplayNameTextBox"
                                                 Grid.Column="1"
                                                 Style="{StaticResource SettingTextBoxStyle}"
                                                 TextChanged="OnSettingChanged"
                                                 Width="500"
                                                 HorizontalAlignment="Left"
                                                 Height="22"
                                                 VerticalAlignment="Bottom"/>
                                </Grid>

                                <Grid Margin="0,5,20,0">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="モデル:"
                                                   Style="{StaticResource SettingLabelStyle}"/>
                                        <TextBox x:Name="EmbeddingModelTextBox"
                                                 Grid.Column="1"
                                                 Style="{StaticResource SettingTextBoxStyle}"
                                                 TextChanged="OnSettingChanged"/>
                                </Grid>

                                <Grid Margin="0,10,20,0">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="エンドポイントURL:"
                                                   Style="{StaticResource SettingLabelStyle}"/>
                                        <TextBox x:Name="EmbeddingApiBaseTextBox"
                                                 Grid.Column="1"
                                                 Style="{StaticResource SettingTextBoxStyle}"
                                                 TextChanged="OnSettingChanged"/>
                                </Grid>

                                <Grid Margin="0,10,20,0">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="次元数:"
                                                   Style="{StaticResource SettingLabelStyle}"/>
                                        <TextBox x:Name="EmbeddingDimensionTextBox"
                                                 Grid.Column="1"
                                                 Style="{StaticResource SettingTextBoxStyle}"
                                                 TextChanged="OnSettingChanged"/>
                                </Grid>

                                <Grid Margin="0,10,20,0">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="APIキー:"
                                                   Style="{StaticResource SettingLabelStyle}"/>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBox x:Name="EmbeddingApiKeyTextBox"
                                                         Foreground="#FF0078D7"
                                                         Padding="2"
                                                         Width="50"
                                                         HorizontalAlignment="Left"
                                                         TextChanged="OnSettingChanged"/>
                                                <Button Content="コピー"
                                                        Margin="10,0,0,0"
                                                        Padding="10,0,10,0"
                                                        Click="EmbeddingApiKeyCopyButton_Click"
                                                        ToolTip="クリップボードにコピー"/>
                                                <Button Content="上書き貼り付け"
                                                        Margin="10,0,0,0"
                                                        Padding="10,0,10,0"
                                                        Click="EmbeddingApiKeyPasteButton_Click"
                                                        ToolTip="クリップボードのテキストで上書き"/>
                                                <Button Content="LLMモデルのAPIキーを貼り付け"
                                                        Margin="10,0,0,0"
                                                        Padding="10,0,10,0"
                                                        Click="PasteLlmModelApiKeyButton_Click"/>
                                        </StackPanel>
                                </Grid>
                        </StackPanel>
                </ScrollViewer>
        </Grid>
</UserControl>
