<UserControl x:Class="CocoroConsole.Controls.EmbeddingSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1100"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SettingLabelStyle"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Margin"
                    Value="0,0,10,0"/>
            <Setter Property="Width"
                    Value="150"/>
        </Style>
        <Style x:Key="SettingTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Foreground"
                    Value="#FF0078D7"/>
            <Setter Property="Padding"
                    Value="2"/>
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
        </Style>
        <Style x:Key="SettingPasswordBoxStyle"
               TargetType="PasswordBox">
            <Setter Property="Foreground"
                    Value="#FF0078D7"/>
            <Setter Property="Padding"
                    Value="2"/>
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
        </Style>
        <Style x:Key="PresetButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#4873CF"/>
            <Setter Property="Foreground"
                    Value="WhiteSmoke"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="10,5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="記憶集合"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="85"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="MemorySetSelectComboBox"
                                      Grid.Column="0"
                                      Margin="0,5,10,5"
                                      SelectionChanged="MemorySetSelectComboBox_SelectionChanged"/>

                            <Button Grid.Column="1"
                                    Content="追加"
                                    Margin="0,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Click="AddMemorySetButton_Click"/>

                            <Button Grid.Column="2"
                                    Content="複製"
                                    Margin="5,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Click="DuplicateMemorySetButton_Click"/>

                            <Button Grid.Column="3"
                                    Content="削除"
                                    Margin="5,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource DeleteButtonStyle}"
                                    Click="DeleteMemorySetButton_Click"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#666666"
                                   Margin="0,0,0,10">
                            記憶集合は人格設定と独立に選択・複製できます。埋め込みモデル設定も記憶集合ごとに持ちます。
                        </TextBlock>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="表示名:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="MemorySetDisplayNameTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>

                        <TextBlock Text="埋め込みモデル"
                                   Margin="0,10,0,5"
                                   Foreground="#4873CF"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#666666"
                                   Margin="0,0,0,10">
                            埋め込みモデルは、この記憶集合の検索と更新で使うベクトル化設定です。
                        </TextBlock>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="モデル:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="EmbeddingModelTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="エンドポイントURL（任意）:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="EmbeddingApiBaseTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="APIキー:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <PasswordBox x:Name="EmbeddingApiKeyPasswordBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingPasswordBoxStyle}"
                                         PasswordChanged="OnPasswordChanged"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
