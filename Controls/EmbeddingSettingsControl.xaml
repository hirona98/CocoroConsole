<UserControl x:Class="CocoroConsole.Controls.EmbeddingSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SettingLabelStyle"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Margin"
                    Value="0,0,10,0"/>
            <Setter Property="Width"
                    Value="160"/>
        </Style>
        <Style x:Key="SettingTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Foreground"
                    Value="#FF0078D7"/>
            <Setter Property="Padding"
                    Value="2"/>
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
        </Style>
        <!-- гғ—гғӘгӮ»гғғгғҲгғңгӮҝгғіе…ұйҖҡгӮ№гӮҝгӮӨгғ« -->
        <Style x:Key="PresetButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#4873CF"/>
            <Setter Property="Foreground"
                    Value="WhiteSmoke"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Background"
                                        Value="#CCCCCC"/>
                                <Setter Property="Foreground"
                                        Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#5A84D9"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#3A62B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
	        <!-- еүҠйҷӨгғңгӮҝгғігҒҜ App.xaml гҒ® DeleteButtonStyle гӮ’дҪҝз”Ё -->
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- жңүеҠ№еҢ– -->
                <CheckBox x:Name="MemoryEnabledCheckBox"
                          Content="иЁҳжҶ¶ж©ҹиғҪпјҲEmbeddingпјүгӮ’дҪҝз”ЁгҒҷгӮӢ - OFFгҒ«гҒҜеҮәжқҘгҒҫгҒӣгӮ“"
                          Foreground="#FF4873CF"
                          IsChecked="True"
                          IsEnabled="False"
                          Checked="MemoryEnabledCheckBox_Changed"
                          Unchecked="MemoryEnabledCheckBox_Changed"
                          Margin="0,5,0,20"
                          ToolTip="Enable memory (embeddings)"/>

                <!-- гғ—гғӘгӮ»гғғгғҲйҒёжҠһ -->
                <GroupBox Header="гғ—гғӘгӮ»гғғгғҲйҒёжҠһ"
                          Margin="0,0,20,20"
                          Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="85"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="PresetSelectComboBox"
                                  Grid.Column="0"
                                  Margin="0,5,10,5"
                                  SelectionChanged="PresetSelectComboBox_SelectionChanged"/>

                        <Button x:Name="AddPresetButton"
                                Grid.Column="1"
                                Content="иҝҪеҠ "
                                Margin="0,5,0,5"
                                Padding="10,5"
                                Click="AddPresetButton_Click"
                                ToolTipService.ShowOnDisabled="True"
                                ToolTip="гғ—гғӘгӮ»гғғгғҲгӮ’иҝҪеҠ "/>

                        <Button x:Name="DuplicatePresetButton"
                                Grid.Column="2"
                                Content="иӨҮиЈҪ"
                                Margin="5,5,0,5"
                                Padding="10,5"
                                Click="DuplicatePresetButton_Click"
                                ToolTipService.ShowOnDisabled="True"
                                ToolTip="зҸҫеңЁгҒ®гғ—гғӘгӮ»гғғгғҲгӮ’иӨҮиЈҪ"/>

                        <Button x:Name="DeletePresetButton"
                                Grid.Column="3"
                                Content="еүҠйҷӨ"
                                Margin="5,5,0,5"
                                Padding="10,5"
                                Style="{StaticResource DeleteButtonStyle}"
                                Click="DeletePresetButton_Click"
                                ToolTipService.ShowOnDisabled="True"
                                ToolTip="гҒ“гҒ®гғ—гғӘгӮ»гғғгғҲгӮ’еүҠйҷӨ"/>
                    </Grid>
                </GroupBox>

                <!-- EmbeddingиЁӯе®ҡ -->
                <GroupBox Header="EmbeddingиЁӯе®ҡ"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <!-- иӯҰе‘ҠгғҶгӮӯгӮ№гғҲ -->
                        <TextBlock Foreground="Red"
                                   Margin="0,0,0,10"
                                   Text="вҖ»иөӨеӯ—й …зӣ®гҒҜдёҖеәҰиЁӯе®ҡгҒ—гҒҹгӮүеӨүжӣҙгҒ—гҒӘгҒ„гҒ§гҒҸгҒ гҒ•гҒ„"/>

                        <!-- гғ—гғӘгӮ»гғғгғҲеҗҚ(memory_id) -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Memory ID:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="MemoryIdTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     ToolTip="иЁҳжҶ¶гғҮгғјгӮҝгғҷгғјгӮ№гҒ®иӯҳеҲҘеӯҗ"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>

                        <!-- Embedding APIгӮӯгғј -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Embedding APIгӮӯгғј:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="EmbeddingApiKeyPasswordBox"
                                         Grid.Column="0"
                                         Foreground="#FF0078D7"
                                         Padding="2"
                                         Width="100"
                                         HorizontalAlignment="Left"
                                         BorderBrush="#CCCCCC"
                                         BorderThickness="1"
                                         ToolTip="з©әж¬„гҒ®е ҙеҗҲгҒҜLLM APIгӮӯгғјгӮ’дҪҝз”Ё"
                                         TextChanged="OnSettingChanged"/>
                                <Button Grid.Column="1"
                                        Content="гӮігғ”гғј"
                                        Margin="10,0,0,0"
                                        Padding="10,0,10,0"
                                        Click="EmbeddingApiKeyCopyButton_Click"
                                        ToolTip="гӮҜгғӘгғғгғ—гғңгғјгғүгҒ«гӮігғ”гғј"/>
                                <Button Grid.Column="2"
                                        Content="дёҠжӣёгҒҚиІјд»ҳгҒ‘"
                                        Margin="10,0,0,0"
                                        Padding="10,0,10,0"
                                        Click="EmbeddingApiKeyPasteOverrideButton_Click"
                                        ToolTip="гӮҜгғӘгғғгғ—гғңгғјгғүгҒ®гғҶгӮӯгӮ№гғҲгҒ§дёҠжӣёгҒҚ"/>
                                <Button Grid.Column="3"
                                        Content="LLMгғўгғҮгғ«гҒ®APIгӮӯгғјгӮ’иІјд»ҳгҒ‘"
                                        Margin="10,0,0,0"
                                        Padding="10,0,10,0"
                                        Click="EmbeddingApiKeyPasteFromLlmApiKeyButton_Click"
                                        ToolTip="дјҡи©ұгӮҝгғ–гҒ®LLM APIгӮӯгғјгҒ§дёҠжӣёгҒҚ"/>
                            </Grid>
                        </Grid>

                        <!-- EmbeddingгғўгғҮгғ« -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="EmbeddingгғўгғҮгғ«:"
                                       Style="{StaticResource SettingLabelStyle}"
                                       Foreground="Red"/>
                            <TextBox x:Name="EmbeddingModelTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     ToolTip="дҫӢ: text-embedding-3-small"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <!-- EmbeddingгғўгғҮгғ«иӘ¬жҳҺпјҲжҠҳгӮҠгҒҹгҒҹгҒҝпјү -->
                        <Expander Header="гғўгғҮгғ«и©ізҙ°иӘ¬жҳҺ"
                                  Margin="160,0,0,5"
                                  IsExpanded="False"
                                  Foreground="#666666">
                            <!-- RichTextBoxгҒ«гҒҷгӮӢгҒ“гҒЁгҒ§гғһгӮҰгӮ№йҒёжҠһ/гӮігғ”гғјеҸҜиғҪгҒ«гҒҷгӮӢ -->
                            <RichTextBox Margin="0,5,0,0"
                                         IsReadOnly="True"
                                         IsReadOnlyCaretVisible="False"
                                         IsTabStop="False"
                                         IsDocumentEnabled="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#666666"
                                         Padding="0"
                                         VerticalScrollBarVisibility="Disabled"
                                         HorizontalScrollBarVisibility="Disabled">
                                <RichTextBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="гӮігғ”гғј"
                                                  Command="ApplicationCommands.Copy"/>
                                        <MenuItem Header="гҒҷгҒ№гҒҰйҒёжҠһ"
                                                  Command="ApplicationCommands.SelectAll"/>
                                    </ContextMenu>
                                </RichTextBox.ContextMenu>
                                <FlowDocument PagePadding="0"
                                              LineHeight="18">
                                    <Paragraph Margin="0">
                                        <Run Text="иЁҳжҶ¶DBгҒ§дҪҝгҒҶгғўгғҮгғ«гӮ’иЁӯе®ҡгҒ—гҒҫгҒҷгҖӮд»ҘдёӢжӣёејҸгҒ§е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ"/>
                                        <LineBreak/>
                                        <Run Text="openai/text-embedding-3-large"/>
                                        <LineBreak/>
                                        <Run Text="gemini/gemini-embedding-001"/>
                                        <LineBreak/>
                                        <Run Text="openrouter/openai/text-embedding-3-large"/>
                                        <LineBreak/>
                                        <Run Text="openrouter/google/gemini-embedding-001"/>
                                        <LineBreak/>
                                        <Run Text="ollama/nomic-embed-textпјҲBASE URLгҒҜ http://localhost:11434пјүвҖ»е•ҸйЎҢгҒӮгҒЈгҒҹгӮүж•ҷгҒҲгҒҰгҒӯ"/>
                                        <LineBreak/>
                                        <Run Text="lm_studio/XXXпјҲBASE URLгҒҜhttp://127.0.0.1:1234/v1пјүвҖ»жңӘеҜҫеҝң"/>
                                        <LineBreak/>
                                        <Run Text="еҸӮиҖғ: "/>
                                        <Hyperlink NavigateUri="https://docs.litellm.ai/docs/embedding/supported_embedding"
                                                   RequestNavigate="Hyperlink_RequestNavigate">
                                            <Run Text="https://docs.litellm.ai/docs/embedding/supported_embedding"/>
                                        </Hyperlink>
                                    </Paragraph>
                                </FlowDocument>
                            </RichTextBox>
                        </Expander>

                        <!-- Embedding Base URL -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Embedding Base URL:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="EmbeddingBaseUrlTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     ToolTip="Embedding APIз”ЁгҒ®гғҷгғјгӮ№URLпјҲз©әж¬„гҒ®е ҙеҗҲгҒҜгғҮгғ•гӮ©гғ«гғҲпјү"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>

                        <!-- Embedding Dimension -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Embeddingж¬Ўе…ғж•°:"
                                       Style="{StaticResource SettingLabelStyle}"
                                       Foreground="Red"/>
                            <TextBox x:Name="EmbeddingDimensionTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     ToolTip="EmbeddingгғҷгӮҜгғҲгғ«гҒ®ж¬Ўе…ғж•°"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>

                        <!-- йЎһдјјгӮЁгғ”гӮҪгғјгғүж•° -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="йЎһдјјгӮЁгғ”гӮҪгғјгғүж•°:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="SimilarEpisodesLimitTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     ToolTip="иЁҳжҶ¶жӨңзҙўжҷӮгҒ«еҸ–еҫ—гҒҷгӮӢйЎһдјјгӮЁгғ”гӮҪгғјгғүгҒ®жңҖеӨ§ж•°пјҲе®ҹйҡӣгҒ«дҪҝз”ЁгҒҷгӮӢиЁҳжҶ¶гҒҜгҒ•гӮүгҒ«зөһгӮҠиҫјгҒҫгӮҢгҒҫгҒҷпјү"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
