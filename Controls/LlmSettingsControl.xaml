                                         TextChanged="OnSettingChanged"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="APIキー:"
                                           Style="{StaticResource SettingLabelStyle}"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBox x:Name="ReflectionSummaryApiKeyTextBox"
                                             Foreground="#FF0078D7"
                                             Padding="2"
                                             Width="50"
                                             HorizontalAlignment="Left"
                                             TextChanged="OnSettingChanged"/>
                                    <Button Content="コピー"
                                            Margin="10,0,0,0"
                                            Padding="10,0,10,0"
                                            Click="ReflectionSummaryApiKeyCopyButton_Click"
                                            ToolTip="クリップボードにコピー"/>
                                    <Button Content="上書き貼り付け"
                                            Margin="10,0,0,0"
                                            Padding="10,0,10,0"
                                            Click="ReflectionSummaryApiKeyPasteButton_Click"
                                            ToolTip="クリップボードのテキストで上書き"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="推論の深さ:"
