                                         Grid.Column="1"
                                         Style="{StaticResource SettingTextBoxStyle}"
                                         TextChanged="OnSettingChanged"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="エンドポイントURL:"
                                           Style="{StaticResource SettingLabelStyle}"/>
                                <TextBox x:Name="DecisionApiBaseTextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingTextBoxStyle}"
                                         TextChanged="OnSettingChanged"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="APIキー:"
                                           Style="{StaticResource SettingLabelStyle}"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBox x:Name="DecisionApiKeyTextBox"
                                             Foreground="#FF0078D7"
                                             Padding="2"
                                             Width="50"
                                             HorizontalAlignment="Left"
                                             TextChanged="OnSettingChanged"/>
                                    <Button Content="コピー"
                                            Margin="10,0,0,0"
                                            Padding="10,0,10,0"
                                            Click="DecisionApiKeyCopyButton_Click"
                                            ToolTip="クリップボードにコピー"/>
                                    <Button Content="上書き貼り付け"
                                            Margin="10,0,0,0"
                                            Padding="10,0,10,0"
                                            Click="DecisionApiKeyPasteButton_Click"
                                            ToolTip="クリップボードのテキストで上書き"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="推論の深さ:"
                                           Style="{StaticResource SettingLabelStyle}"/>
                                <TextBox x:Name="DecisionReasoningEffortTextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingTextBoxStyle}"
                                         TextChanged="OnSettingChanged"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="最大出力トークン:"
                                           Style="{StaticResource SettingLabelStyle}"/>
                                <TextBox x:Name="DecisionMaxOutputTokensTextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingTextBoxStyle}"
                                         TextChanged="OnSettingChanged"/>
                            </Grid>
                            <CheckBox x:Name="DecisionWebSearchCheckBox"
                                      Content="Web検索を有効にする"
                                      Foreground="#FF4873CF"
                                      Margin="0,8,0,0"
                                      Checked="OnCheckBoxChanged"
                                      Unchecked="OnCheckBoxChanged"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="記憶更新の整理"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <CheckBox x:Name="MemoryUseExpressionModelCheckBox"
                                  Content="表現生成と同じモデルを使用する"
                                  Foreground="#FF4873CF"
                                  Margin="0,0,0,8"
                                  IsChecked="True"
                                  Checked="UseExpressionModelCheckBox_Changed"
                                  Unchecked="UseExpressionModelCheckBox_Changed"/>
                        <StackPanel x:Name="MemorySettingsPanel">
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="モデル:"
                                           Style="{StaticResource SettingLabelStyle}"/>
                                <TextBox x:Name="MemoryModelTextBox"
