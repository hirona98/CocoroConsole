<UserControl x:Class="CocoroConsole.Controls.LlmSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1100"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SettingLabelStyle"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Margin"
                    Value="0,0,10,0"/>
            <Setter Property="Width"
                    Value="140"/>
        </Style>
        <Style x:Key="SettingTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Foreground"
                    Value="#FF0078D7"/>
            <Setter Property="Padding"
                    Value="2"/>
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
        </Style>
        <Style x:Key="PresetButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#4873CF"/>
            <Setter Property="Foreground"
                    Value="WhiteSmoke"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="10,5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <CheckBox x:Name="IsUseLLMCheckBox"
                          Content="会話機能（LLM）を使用する"
                          Foreground="#FF4873CF"
                          Checked="IsUseLLMCheckBox_Changed"
                          Unchecked="IsUseLLMCheckBox_Changed"
                          Margin="0,5,0,20"/>

                <GroupBox Header="モデルプリセット"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="85"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="PresetSelectComboBox"
                                      Grid.Column="0"
                                      Margin="0,5,10,5"
                                      SelectionChanged="PresetSelectComboBox_SelectionChanged"/>

                            <Button Grid.Column="1"
                                    Content="追加"
                                    Margin="0,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Click="AddPresetButton_Click"/>

                            <Button Grid.Column="2"
                                    Content="複製"
                                    Margin="5,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Click="DuplicatePresetButton_Click"/>

                            <Button Grid.Column="3"
                                    Content="削除"
                                    Margin="5,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource DeleteButtonStyle}"
                                    Click="DeletePresetButton_Click"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="表示名:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="PresetNameTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="observation_interpretation"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#666666"
                                   Margin="0,0,0,8">
                            観測解釈 role の object を JSON で編集します。
                        </TextBlock>
                        <TextBox x:Name="ObservationRoleJsonTextBox"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Height="180"
                                 FontFamily="Consolas"
                                 Foreground="#FF0078D7"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 TextChanged="OnSettingChanged"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="decision_generation"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#666666"
                                   Margin="0,0,0,8">
                            意図判断 role の object を JSON で編集します。
                        </TextBlock>
                        <TextBox x:Name="DecisionRoleJsonTextBox"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Height="180"
                                 FontFamily="Consolas"
                                 Foreground="#FF0078D7"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 TextChanged="OnSettingChanged"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="expression_generation"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#666666"
                                   Margin="0,0,0,8">
                            表現生成 role の object を JSON で編集します。
                        </TextBlock>
                        <TextBox x:Name="ExpressionRoleJsonTextBox"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Height="180"
                                 FontFamily="Consolas"
                                 Foreground="#FF0078D7"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 TextChanged="OnSettingChanged"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="memory_interpretation"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#666666"
                                   Margin="0,0,0,8">
                            記憶解釈 role の object を JSON で編集します。
                        </TextBlock>
                        <TextBox x:Name="MemoryRoleJsonTextBox"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Height="180"
                                 FontFamily="Consolas"
                                 Foreground="#FF0078D7"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 TextChanged="OnSettingChanged"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="embedding"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#666666"
                                   Margin="0,0,0,8">
                            埋め込み role の object を JSON で編集します。
                        </TextBlock>
                        <TextBox x:Name="EmbeddingRoleJsonTextBox"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Height="180"
                                 FontFamily="Consolas"
                                 Foreground="#FF0078D7"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 TextChanged="OnSettingChanged"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
