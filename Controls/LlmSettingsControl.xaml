                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="内省結果の要約"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <CheckBox x:Name="ReflectionSummaryUseExpressionModelCheckBox"
