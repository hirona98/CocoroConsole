                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="モデル:"
                                           Style="{StaticResource SettingLabelStyle}"/>
                                <TextBox x:Name="ReflectionSummaryModelTextBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingTextBoxStyle}"
                                         TextChanged="OnSettingChanged"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="エンドポイントURL:"
                                           Style="{StaticResource SettingLabelStyle}"/>
                                <TextBox x:Name="ReflectionSummaryApiBaseTextBox"
                                         Grid.Column="1"
