                    <StackPanel>
                        <CheckBox x:Name="EventEvidenceUseExpressionModelCheckBox"
                                  Content="表現生成と同じモデルを使用する"
                                  Foreground="#FF4873CF"
                                  Margin="0,0,0,8"
                                  IsChecked="True"
                                  Checked="UseExpressionModelCheckBox_Changed"
                                  Unchecked="UseExpressionModelCheckBox_Changed"/>
                        <StackPanel x:Name="EventEvidenceSettingsPanel">
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
