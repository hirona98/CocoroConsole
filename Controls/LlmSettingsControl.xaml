<UserControl x:Class="CocoroConsole.Controls.LlmSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1250"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SettingLabelStyle"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Margin"
                    Value="0,0,10,0"/>
            <Setter Property="Width"
                    Value="150"/>
        </Style>
        <Style x:Key="SettingTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Foreground"
                    Value="#FF0078D7"/>
            <Setter Property="Padding"
                    Value="2"/>
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
        </Style>
        <Style x:Key="SettingPasswordBoxStyle"
               TargetType="PasswordBox">
            <Setter Property="Foreground"
                    Value="#FF0078D7"/>
            <Setter Property="Padding"
                    Value="2"/>
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
        </Style>
        <Style x:Key="PresetButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#4873CF"/>
            <Setter Property="Foreground"
                    Value="WhiteSmoke"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="10,5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <CheckBox x:Name="IsUseLLMCheckBox"
                          Content="会話機能（言語モデル）を使用する"
                          Foreground="#FF4873CF"
                          Checked="IsUseLLMCheckBox_Changed"
                          Unchecked="IsUseLLMCheckBox_Changed"
                          Margin="0,5,0,20"/>

                <GroupBox Header="モデルプリセット"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="85"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="PresetSelectComboBox"
                                      Grid.Column="0"
                                      Margin="0,5,10,5"
                                      SelectionChanged="PresetSelectComboBox_SelectionChanged"/>

                            <Button Grid.Column="1"
                                    Content="追加"
                                    Margin="0,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Click="AddPresetButton_Click"/>

                            <Button Grid.Column="2"
                                    Content="複製"
                                    Margin="5,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Click="DuplicatePresetButton_Click"/>

                            <Button Grid.Column="3"
                                    Content="削除"
                                    Margin="5,5,0,5"
                                    Padding="10,5"
                                    Style="{StaticResource DeleteButtonStyle}"
                                    Click="DeletePresetButton_Click"/>
                        </Grid>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="表示名:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="PresetNameTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="観測解釈"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="モデル:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="ObservationModelTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="エンドポイントURL（任意）:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="ObservationApiBaseTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="APIキー:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <PasswordBox x:Name="ObservationApiKeyPasswordBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingPasswordBoxStyle}"
                                         PasswordChanged="OnPasswordChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="推論の深さ:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="ObservationReasoningEffortTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="意図判断"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="モデル:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="DecisionModelTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="エンドポイントURL（任意）:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="DecisionApiBaseTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="APIキー:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <PasswordBox x:Name="DecisionApiKeyPasswordBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingPasswordBoxStyle}"
                                         PasswordChanged="OnPasswordChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="推論の深さ:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="DecisionReasoningEffortTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="表現生成"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="モデル:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="ExpressionModelTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="エンドポイントURL（任意）:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="ExpressionApiBaseTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="APIキー:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <PasswordBox x:Name="ExpressionApiKeyPasswordBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingPasswordBoxStyle}"
                                         PasswordChanged="OnPasswordChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="推論の深さ:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="ExpressionReasoningEffortTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="記憶解釈"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="モデル:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="MemoryModelTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="エンドポイントURL（任意）:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="MemoryApiBaseTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="APIキー:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <PasswordBox x:Name="MemoryApiKeyPasswordBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SettingPasswordBoxStyle}"
                                         PasswordChanged="OnPasswordChanged"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="推論の深さ:"
                                       Style="{StaticResource SettingLabelStyle}"/>
                            <TextBox x:Name="MemoryReasoningEffortTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SettingTextBoxStyle}"
                                     TextChanged="OnSettingChanged"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
