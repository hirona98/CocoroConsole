<UserControl x:Class="CocoroConsole.Controls.PromptSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="800">

        <UserControl.Resources>
                <Style x:Key="PromptGroupBoxStyle"
                       TargetType="GroupBox">
                        <Setter Property="Background"
                                Value="White"/>
                        <Setter Property="BorderBrush"
                                Value="#CCCCCC"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Margin"
                                Value="0,0,20,15"/>
                        <Setter Property="FontSize"
                                Value="14"/>
                        <Setter Property="Foreground"
                                Value="#4873CF"/>
                        <Setter Property="SnapsToDevicePixels"
                                Value="True"/>
                </Style>
                <Style x:Key="SettingLabelStyle"
                       TargetType="TextBlock">
                        <Setter Property="VerticalAlignment"
                                Value="Center"/>
                        <Setter Property="Margin"
                                Value="0,0,10,0"/>
                        <Setter Property="Width"
                                Value="140"/>
                        <Setter Property="Foreground"
                                Value="#4873CF"/>
                </Style>
                <Style x:Key="SettingTextBoxStyle"
                       TargetType="TextBox">
                        <Setter Property="Foreground"
                                Value="#FF0078D7"/>
                        <Setter Property="Padding"
                                Value="2"/>
                        <Setter Property="BorderBrush"
                                Value="#CCCCCC"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                </Style>
                <Style x:Key="PresetButtonStyle"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="#4873CF"/>
                        <Setter Property="Foreground"
                                Value="WhiteSmoke"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Padding"
                                Value="10,5"/>
                </Style>
        </UserControl.Resources>

        <Grid SnapsToDevicePixels="True"
              UseLayoutRounding="True">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,0,20">
                                <GroupBox Header="人格設定一覧"
                                          Style="{StaticResource PromptGroupBoxStyle}">
                                        <StackPanel Margin="10">
                                                <Grid Margin="0,0,0,15">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="85"/>
                                                        </Grid.ColumnDefinitions>

                                                        <ComboBox x:Name="PersonaSelectComboBox"
                                                                  Grid.Column="0"
                                                                  Margin="0,5,10,5"
                                                                  SelectionChanged="PersonaSelectComboBox_SelectionChanged"/>

                                                        <Button Grid.Column="1"
                                                                Content="追加"
                                                                Margin="0,5,0,5"
                                                                Padding="10,5"
                                                                Style="{StaticResource PresetButtonStyle}"
                                                                Click="AddPersonaButton_Click"/>

                                                        <Button Grid.Column="2"
                                                                Content="複製"
                                                                Margin="5,5,0,5"
                                                                Padding="10,5"
                                                                Style="{StaticResource PresetButtonStyle}"
                                                                Click="DuplicatePersonaButton_Click"/>

                                                        <Button Grid.Column="3"
                                                                Content="削除"
                                                                Margin="5,5,0,5"
                                                                Padding="10,5"
                                                                Style="{StaticResource DeleteButtonStyle}"
                                                                Click="DeletePersonaButton_Click"/>
                                                </Grid>

                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="#666666">
                            `persona_text`、`addon_text`、`core_persona`、`expression_style` を 1 つの人格設定として編集します。
                                                </TextBlock>
                                        </StackPanel>
                                </GroupBox>

                                <GroupBox Header="基本テキスト"
                                          Style="{StaticResource PromptGroupBoxStyle}">
                                        <StackPanel Margin="10">
                                                <Grid Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="140"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="表示名:"
                                                                   Style="{StaticResource SettingLabelStyle}"/>
                                                        <TextBox x:Name="DisplayNameTextBox"
                                                                 Grid.Column="1"
                                                                 Style="{StaticResource SettingTextBoxStyle}"
                                                                 TextChanged="OnSettingChanged"/>
                                                </Grid>

                                                <Grid Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="140"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="ユーザーの呼び方:"
                                                                   Style="{StaticResource SettingLabelStyle}"/>
                                                        <TextBox x:Name="SecondPersonLabelTextBox"
                                                                 Grid.Column="1"
                                                                 Style="{StaticResource SettingTextBoxStyle}"
                                                                 TextChanged="OnSettingChanged"/>
                                                </Grid>

                                                <TextBlock Text="persona_text"
                                                           Margin="0,10,0,5"
                                                           Foreground="#4873CF"/>
                                                <TextBox x:Name="PersonaTextBox"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Height="180"
                                                         Foreground="#FF0078D7"
                                                         BorderBrush="#CCCCCC"
                                                         BorderThickness="1"
                                                         TextChanged="OnSettingChanged"/>

                                                <TextBlock Text="addon_text"
                                                           Margin="0,10,0,5"
                                                           Foreground="#4873CF"/>
                                                <TextBox x:Name="AddonTextBox"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Height="120"
                                                         Foreground="#FF0078D7"
                                                         BorderBrush="#CCCCCC"
                                                         BorderThickness="1"
                                                         TextChanged="OnSettingChanged"/>
                                        </StackPanel>
                                </GroupBox>

                                <GroupBox Header="core_persona"
                                          Style="{StaticResource PromptGroupBoxStyle}">
                                        <StackPanel Margin="10">
                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="#666666"
                                                           Margin="0,0,0,8">
                            `core_persona` の object を JSON で編集します。例: `self_image`、`core_values`、`relation_baseline`
                                                </TextBlock>
                                                <TextBox x:Name="CorePersonaJsonTextBox"
                                                         AcceptsReturn="True"
                                                         TextWrapping="NoWrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         Height="220"
                                                         FontFamily="Consolas"
                                                         Foreground="#FF0078D7"
                                                         BorderBrush="#CCCCCC"
                                                         BorderThickness="1"
                                                         TextChanged="OnSettingChanged"/>
                                        </StackPanel>
                                </GroupBox>

                                <GroupBox Header="expression_style"
                                          Style="{StaticResource PromptGroupBoxStyle}">
                                        <StackPanel Margin="10">
                                                <TextBlock TextWrapping="Wrap"
                                                           Foreground="#666666"
                                                           Margin="0,0,0,8">
                            `expression_style` の object を JSON で編集します。少なくとも `tone` を含めてください。
                                                </TextBlock>
                                                <TextBox x:Name="ExpressionStyleJsonTextBox"
                                                         AcceptsReturn="True"
                                                         TextWrapping="NoWrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         Height="220"
                                                         FontFamily="Consolas"
                                                         Foreground="#FF0078D7"
                                                         BorderBrush="#CCCCCC"
                                                         BorderThickness="1"
                                                         TextChanged="OnSettingChanged"/>
                                        </StackPanel>
                                </GroupBox>
                        </StackPanel>
                </ScrollViewer>
        </Grid>
</UserControl>
