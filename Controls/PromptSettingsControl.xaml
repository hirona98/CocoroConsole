<UserControl x:Class="CocoroConsole.Controls.PromptSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SettingLabelStyle"
               TargetType="TextBlock">
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Margin"
                    Value="0,0,10,0"/>
            <Setter Property="Width"
                    Value="150"/>
            <Setter Property="Foreground"
                    Value="#4873CF"/>
        </Style>
        <Style x:Key="SettingTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Foreground"
                    Value="#FF0078D7"/>
            <Setter Property="Padding"
                    Value="2"/>
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
        </Style>
        <Style x:Key="PresetButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#4873CF"/>
            <Setter Property="Foreground"
                    Value="WhiteSmoke"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="10,5"/>
        </Style>
    </UserControl.Resources>

    <Grid SnapsToDevicePixels="True"
          UseLayoutRounding="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,20">
                <Grid Margin="0,0,20,0" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="85"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="PersonaSelectComboBox"
                              Grid.Column="0"
                              Margin="0,5,10,5"
                              SelectionChanged="PersonaSelectComboBox_SelectionChanged" Width="500"/>

                    <Button Grid.Column="1"
                            Content="追加"
                            Margin="0,5,0,5"
                            Padding="10,5"
                            Style="{StaticResource PresetButtonStyle}"
                            Click="AddPersonaButton_Click"/>

                    <Button Grid.Column="2"
                            Content="複製"
                            Margin="5,5,0,5"
                            Padding="10,5"
                            Style="{StaticResource PresetButtonStyle}"
                            Click="DuplicatePersonaButton_Click"/>

                    <Button Grid.Column="3"
                            Content="削除"
                            Margin="5,5,0,5"
                            Padding="10,5"
                            Style="{StaticResource DeleteButtonStyle}"
                            Click="DeletePersonaButton_Click"/>
                </Grid>

                <Grid Margin="0,20,20,0" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="プリセット名:"
                               Style="{StaticResource SettingLabelStyle}"/>
                    <TextBox x:Name="DisplayNameTextBox"
                             Grid.Column="1"
                             Style="{StaticResource SettingTextBoxStyle}"
                             TextChanged="OnSettingChanged" Width="500"/>
                </Grid>

                <TextBlock Text="人格本文"
                           Margin="0,20,20,5"
                           Foreground="#4873CF"/>
                <TextBlock Text="役割、距離感、価値観、話し方、強い原則を自由文でまとめて書きます。"
                           Foreground="#666666"
                           Margin="0,0,20,5"/>
                <TextBox x:Name="PersonaPromptTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="320"
                         Margin="0,0,20,0"
                         Foreground="#FF0078D7"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         TextChanged="OnSettingChanged"/>

                <TextBlock Text="表現補助"
                           Margin="0,20,20,5"
                           Foreground="#4873CF"/>
                <TextBlock Text="会話時の表現生成でだけ使う補助指示を入れます。表情指定や出力補助に使えます。"
                           Foreground="#666666"
                           Margin="0,0,20,5"/>
                <TextBox x:Name="ExpressionAddonTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="160"
                         Margin="0,0,20,0"
                         Foreground="#FF0078D7"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         TextChanged="OnSettingChanged"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
