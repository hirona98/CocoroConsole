<UserControl x:Class="CocoroConsole.Controls.ApiDocumentationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="800">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="ドキュメント"
                          Margin="0,0,20,20"
                          Padding="10">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#666666">
                            OtomeKairo が公開する説明ドキュメントを表示します。
                        </TextBlock>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="TOKEN:"
                                       Foreground="#666666"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="ConsoleAccessTokenTextBox"
                                     Grid.Column="1"
                                     IsReadOnly="True"
                                     BorderThickness="1"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Disabled"
                                     Foreground="#666666"
                                     Padding="4"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"/>
                        </Grid>

                        <StackPanel x:Name="DocsSectionsPanel"
                                    Margin="0,10,0,0"/>

                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
