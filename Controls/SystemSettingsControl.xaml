<UserControl x:Class="CocoroConsole.Controls.SystemSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CocoroConsole.Controls"
             mc:Ignorable="d"
             d:DesignHeight="1300"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SettingsGroupBoxStyle"
               TargetType="GroupBox">
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Foreground"
                    Value="#4873CF"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="視覚キャプチャ"
                          Margin="0,0,20,20"
                          Style="{StaticResource SettingsGroupBoxStyle}">
                    <Border Background="White"
                            Padding="10">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#666666"
                                       Margin="0,0,0,10">
                                OtomeKairo から `vision.capture_request` を受けたときのローカルキャプチャ条件を設定します。
                            </TextBlock>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="アイドル時スキップ:"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         x:Name="VisualCaptureIdleTimeoutMinutesTextBox"
                                         Foreground="#FF0078D7"
                                         Padding="2"
                                         Width="60"
                                         Margin="10,0,10,0"
                                         ToolTip="ユーザーがこの分数以上操作していない場合は、キャプチャ要求が来てもスキップします。0で無効。"/>
                                <TextBlock Grid.Column="2"
                                           Text="分（0で無効）"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Fill="#E0E0E0"
                                       Height="1"
                                       Margin="0,10,0,10"/>

                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#666666"
                                       Margin="0,0,0,10">
                                観測対象の `vision_source_id` と visual watch 相当の判定は OtomeKairo 側で管理します。
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#666666"
                                       Margin="0,0,0,10">
                                アクティブウィンドウのタイトルに対して正規表現でマッチ判定し、マッチした場合は画面キャプチャをスキップします。
                            </TextBlock>

                            <TextBox x:Name="ExcludeWindowTitlePatternsTextBox"
                                     Foreground="#FF0078D7"
                                     Padding="2"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="120"
                                     ToolTip="1行に1つ。正規表現。"/>
                        </StackPanel>
                    </Border>
                </GroupBox>

                <GroupBox Header="自律起床"
                          Margin="0,0,20,20"
                          Style="{StaticResource SettingsGroupBoxStyle}">
                    <Border Background="White"
                            Padding="10">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#666666"
                                       Margin="0,0,0,10">
                                `wake_policy` を編集します。無効時は `mode=disabled`、有効時は `mode=interval` を使います。
                            </TextBlock>

                            <CheckBox x:Name="WakePolicyEnabledCheckBox"
                                      Content="自律起床を有効にする"
                                      Margin="0,5,0,10"
                                      Foreground="#FF4873CF"/>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="起床間隔:"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         x:Name="WakeIntervalSecondsTextBox"
                                         Foreground="#FF0078D7"
                                         Padding="2"
                                         Width="60"
                                         Margin="10,0,10,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="秒"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </GroupBox>

                <GroupBox Header="音声認識設定"
                          Margin="0,0,20,20"
                          Style="{StaticResource SettingsGroupBoxStyle}">
                    <Border Background="White"
                            Padding="10">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#666666"
                                       Margin="0,0,0,10">
                                マイクと話者識別の設定を行います。話者登録すると特定の人物の声だけを認識します。
                            </TextBlock>
                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="入力しきい値:"
                                           VerticalAlignment="Center"/>
                                <Slider Grid.Column="1"
                                        x:Name="MicThresholdSlider"
                                        Minimum="-50"
                                        Maximum="0"
                                        Value="-45"
                                        TickFrequency="10"
                                        TickPlacement="BottomRight"
                                        Margin="10,0,10,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ElementName=MicThresholdSlider, Path=Value, StringFormat='{}{0:0} dB'}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#666666"
                                       Margin="0,0,0,10">
                                ※値が低いほど（-50dBに近いほど）音声を拾いやすくなりますが、環境音も拾いやすくなります。
                            </TextBlock>

                            <local:SpeakerManagementControl x:Name="SpeakerManagementControl"
                                                            Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
