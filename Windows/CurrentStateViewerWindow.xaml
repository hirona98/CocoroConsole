<Window x:Class="CocoroConsole.Windows.CurrentStateViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CocoroAI 現在状態ビューアー"
        Width="700"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Icon="/Resource/logo.ico">

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="10">
                        <StackPanel Orientation="Horizontal">
                                <Button x:Name="RefreshButton"
                                        Content="現在状態を更新"
                                        Width="120"
                                        Height="28"
                                        Margin="0,0,16,0"
                                        Click="RefreshButton_Click"/>
                                <CheckBox x:Name="AutoRefreshCheckBox"
                                          Content="自動更新"
                                          IsChecked="True"
                                          VerticalAlignment="Center"
                                          Margin="0,0,16,0"
                                          Checked="AutoRefreshCheckBox_Changed"
                                          Unchecked="AutoRefreshCheckBox_Changed"/>
                                <TextBlock Text="現在状態を inspection API から表示します。"
                                           VerticalAlignment="Center"
                                           Foreground="#444444"/>
                        </StackPanel>
                </Border>

                <TabControl Grid.Row="1"
                            Margin="8">
                        <TabItem Header="概要">
                                <ScrollViewer Margin="8"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                                <StackPanel.Resources>
                                                        <Style x:Key="OverviewSection" TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="#DDDDDD"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Padding" Value="10"/>
                                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                        </Style>
                                                        <Style x:Key="OverviewTitle" TargetType="TextBlock">
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="FontSize" Value="14"/>
                                                                <Setter Property="Margin" Value="0,0,0,6"/>
                                                        </Style>
                                                        <Style x:Key="OverviewBody" TargetType="TextBlock">
                                                                <Setter Property="FontFamily" Value="Meiryo UI"/>
                                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                                <Setter Property="LineHeight" Value="21"/>
                                                        </Style>
                                                </StackPanel.Resources>

                                                <Border Style="{StaticResource OverviewSection}" Background="#F7FAFF">
                                                        <StackPanel>
                                                                <TextBlock Text="現在の要点" Style="{StaticResource OverviewTitle}"/>
                                                                <TextBlock x:Name="CurrentSummaryTextBlock" Style="{StaticResource OverviewBody}"/>
                                                        </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource OverviewSection}">
                                                        <StackPanel>
                                                                <TextBlock Text="実行状態" Style="{StaticResource OverviewTitle}"/>
                                                                <TextBlock x:Name="RuntimeOverviewTextBlock" Style="{StaticResource OverviewBody}"/>
                                                        </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource OverviewSection}">
                                                        <StackPanel>
                                                                <TextBlock Text="進行中アクション" Style="{StaticResource OverviewTitle}"/>
                                                                <TextBlock x:Name="CurrentActionTextBlock" Style="{StaticResource OverviewBody}"/>
                                                        </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource OverviewSection}">
                                                        <StackPanel>
                                                                <TextBlock Text="気分・活動" Style="{StaticResource OverviewTitle}"/>
                                                                <StackPanel x:Name="MoodActivityPanel"/>
                                                        </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource OverviewSection}">
                                                        <StackPanel>
                                                                <TextBlock Text="視覚日次要約" Style="{StaticResource OverviewTitle}"/>
                                                                <TextBlock x:Name="VisualSummaryTextBlock" Style="{StaticResource OverviewBody}"/>
                                                        </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource OverviewSection}">
                                                        <StackPanel>
                                                                <TextBlock Text="世界状態・ドライブ・意図" Style="{StaticResource OverviewTitle}"/>
                                                                <StackPanel x:Name="WorldDriveIntentPanel"/>
                                                        </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource OverviewSection}">
                                                        <StackPanel>
                                                                <TextBlock Text="能力・定期観測" Style="{StaticResource OverviewTitle}"/>
                                                                <StackPanel x:Name="CapabilityObservationPanel"/>
                                                        </StackPanel>
                                                </Border>
                                        </StackPanel>
                                </ScrollViewer>
                        </TabItem>
                        <TabItem Header="現在状態">
                                <Grid Margin="8">
                                        <TextBox x:Name="CurrentStateTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"/>
                                </Grid>
                        </TabItem>
                        <TabItem Header="実行詳細">
                                <Grid Margin="8">
                                        <TextBox x:Name="RuntimeDetailTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"/>
                                </Grid>
                        </TabItem>
                        <TabItem Header="能力状態">
                                <Grid Margin="8">
                                        <TextBox x:Name="CapabilityInspectionTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"/>
                                </Grid>
                        </TabItem>
                </TabControl>

                <Border Grid.Row="2"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,1,0,0"
                        Padding="10,6">
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="inspection API から現在状態を表示します。"/>
                </Border>
        </Grid>
</Window>
