<Window x:Class="CocoroConsole.Windows.CurrentStateViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="現在状態ビューアー"
        Width="1200"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Icon="/Resource/logo.ico">

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="10">
                        <StackPanel Orientation="Horizontal">
                                <Button x:Name="RefreshButton"
                                        Content="現在状態を更新"
                                        Width="120"
                                        Height="28"
                                        Margin="0,0,16,0"
                                        Click="RefreshButton_Click"/>
                                <TextBlock Text="point-in-time の current-state snapshot を inspection API から表示します。"
                                           VerticalAlignment="Center"
                                           Foreground="#444444"/>
                        </StackPanel>
                </Border>

                <TabControl Grid.Row="1"
                            Margin="8">
                        <TabItem Header="概要">
                                <Grid Margin="8">
                                        <TextBox x:Name="OverviewTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"/>
                                </Grid>
                        </TabItem>
                        <TabItem Header="current_state">
                                <Grid Margin="8">
                                        <TextBox x:Name="CurrentStateTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"/>
                                </Grid>
                        </TabItem>
                        <TabItem Header="runtime_detail">
                                <Grid Margin="8">
                                        <TextBox x:Name="RuntimeDetailTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"/>
                                </Grid>
                        </TabItem>
                        <TabItem Header="capability_inspection">
                                <Grid Margin="8">
                                        <TextBox x:Name="CapabilityInspectionTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"/>
                                </Grid>
                        </TabItem>
                </TabControl>

                <Border Grid.Row="2"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,1,0,0"
                        Padding="10,6">
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="inspection API に接続して current-state snapshot を読み込みます。"/>
                </Border>
        </Grid>
</Window>
