<Window x:Class="CocoroConsole.Windows.JudgmentTraceViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CocoroAI 判断トレースビューアー"
        Width="1000"
        Height="900"
        WindowStartupLocation="CenterOwner"
        Icon="/Resource/logo.ico">

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="10">
                        <StackPanel Orientation="Horizontal">
                                <Button x:Name="RefreshButton"
                                        Content="一覧を更新"
                                        Width="110"
                                        Height="28"
                                        Margin="0,0,10,0"
                                        Click="RefreshButton_Click"/>
                                <Button x:Name="ReloadTraceButton"
                                        Content="選択中を再読込"
                                        Width="120"
                                        Height="28"
                                        Margin="0,0,16,0"
                                        Click="ReloadTraceButton_Click"/>
                                <TextBlock Text="最近の判断と根拠を inspection API から表示します。"
                                           VerticalAlignment="Center"
                                           Foreground="#444444"/>
                        </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                BorderBrush="#E0E0E0"
                                BorderThickness="0,0,1,0"
                                Padding="8">
                                <DataGrid x:Name="CycleListDataGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionChanged="CycleListDataGrid_SelectionChanged"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          AlternatingRowBackground="#F9F9F9">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Header="開始"
                                                                    Binding="{Binding StartedAtDisplay, Mode=OneWay}"
                                                                    Width="90"/>
                                                <DataGridTextColumn Header="きっかけ"
                                                                    Binding="{Binding TriggerKind, Mode=OneWay}"
                                                                    Width="110"/>
                                                <DataGridTextColumn Header="結果"
                                                                    Binding="{Binding ResultKind, Mode=OneWay}"
                                                                    Width="55"/>
                                                <DataGridTextColumn Header="失敗"
                                                                    Binding="{Binding FailedDisplay, Mode=OneWay}"
                                                                    Width="40">
                                                        <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                        <Setter Property="HorizontalAlignment"
                                                                                Value="Center"/>
                                                                        <Setter Property="TextAlignment"
                                                                                Value="Center"/>
                                                                </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                        <DataGridTextColumn.HeaderStyle>
                                                                <Style TargetType="DataGridColumnHeader">
                                                                        <Setter Property="HorizontalContentAlignment"
                                                                                Value="Center"/>
                                                                </Style>
                                                        </DataGridTextColumn.HeaderStyle>
                                                </DataGridTextColumn>
                                        </DataGrid.Columns>
                                </DataGrid>
                        </Border>

                        <Grid Grid.Column="2"
                              Margin="0,0,0,0">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="8,0,8,8">
                                        <StackPanel>
                                                <TextBlock x:Name="SelectedCycleTitleTextBlock"
                                                           Text="cycle 未選択"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock x:Name="SelectedCycleMetaTextBlock"
                                                           Text=""
                                                           Foreground="#555555"/>
                                        </StackPanel>
                                </Border>

                                <TabControl Grid.Row="1">
                                        <TabItem Header="要点">
                                                <ScrollViewer Margin="8"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                        <StackPanel>
                                                                <StackPanel.Resources>
                                                                        <Style x:Key="OverviewSection" TargetType="Border">
                                                                                <Setter Property="BorderBrush" Value="#DDDDDD"/>
                                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                                <Setter Property="Padding" Value="10"/>
                                                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                                        </Style>
                                                                        <Style x:Key="OverviewTitle" TargetType="TextBlock">
                                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                <Setter Property="FontSize" Value="14"/>
                                                                                <Setter Property="Margin" Value="0,0,0,6"/>
                                                                        </Style>
                                                                        <Style x:Key="OverviewBody" TargetType="TextBlock">
                                                                                <Setter Property="FontFamily" Value="Meiryo UI"/>
                                                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                                                <Setter Property="LineHeight" Value="21"/>
                                                                        </Style>
                                                                </StackPanel.Resources>

                                                                <Border Style="{StaticResource OverviewSection}" Background="#F7FAFF">
                                                                        <StackPanel>
                                                                                <TextBlock Text="この判断の結論" Style="{StaticResource OverviewTitle}"/>
                                                                                <TextBlock x:Name="JudgmentSummaryTextBlock" Style="{StaticResource OverviewBody}"/>
                                                                        </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource OverviewSection}">
                                                                        <StackPanel>
                                                                                <TextBlock Text="入力と状況" Style="{StaticResource OverviewTitle}"/>
                                                                                <TextBlock x:Name="InputContextOverviewTextBlock" Style="{StaticResource OverviewBody}"/>
                                                                        </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource OverviewSection}">
                                                                        <StackPanel>
                                                                                <TextBlock Text="判断理由" Style="{StaticResource OverviewTitle}"/>
                                                                                <TextBlock x:Name="DecisionReasonOverviewTextBlock" Style="{StaticResource OverviewBody}"/>
                                                                        </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource OverviewSection}">
                                                                        <StackPanel>
                                                                                <TextBlock Text="根拠" Style="{StaticResource OverviewTitle}"/>
                                                                                <TextBlock x:Name="EvidenceOverviewTextBlock" Style="{StaticResource OverviewBody}"/>
                                                                        </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource OverviewSection}">
                                                                        <StackPanel>
                                                                                <TextBlock Text="想起" Style="{StaticResource OverviewTitle}"/>
                                                                                <TextBlock x:Name="RecallOverviewTextBlock" Style="{StaticResource OverviewBody}"/>
                                                                        </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource OverviewSection}">
                                                                        <StackPanel>
                                                                                <TextBlock Text="前景化と派生 view" Style="{StaticResource OverviewTitle}"/>
                                                                                <StackPanel x:Name="CognitiveContextOverviewPanel"/>
                                                                        </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource OverviewSection}">
                                                                        <StackPanel>
                                                                                <TextBlock Text="世界状態" Style="{StaticResource OverviewTitle}"/>
                                                                                <TextBlock x:Name="WorldStateOverviewTextBlock" Style="{StaticResource OverviewBody}"/>
                                                                        </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource OverviewSection}">
                                                                        <StackPanel>
                                                                                <TextBlock Text="活動" Style="{StaticResource OverviewTitle}"/>
                                                                                <TextBlock x:Name="ActivityOverviewTextBlock" Style="{StaticResource OverviewBody}"/>
                                                                        </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource OverviewSection}">
                                                                        <StackPanel>
                                                                                <TextBlock Text="記憶反映" Style="{StaticResource OverviewTitle}"/>
                                                                                <TextBlock x:Name="MemoryOverviewTextBlock" Style="{StaticResource OverviewBody}"/>
                                                                        </StackPanel>
                                                                </Border>
                                                        </StackPanel>
                                                </ScrollViewer>
                                        </TabItem>
                                        <TabItem Header="根拠の詳細">
                                                <Grid Margin="8">
                                                        <TextBox x:Name="EvidenceResolutionTraceTextBox"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Auto"
                                                                 FontFamily="Consolas"
                                                                 TextWrapping="NoWrap"/>
                                                </Grid>
                                        </TabItem>
                                        <TabItem Header="想起の詳細">
                                                <Grid Margin="8">
                                                        <TextBox x:Name="RecallTraceTextBox"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Auto"
                                                                 FontFamily="Consolas"
                                                                 TextWrapping="NoWrap"/>
                                                </Grid>
                                        </TabItem>
                                        <TabItem Header="活動の詳細">
                                                <Grid Margin="8">
                                                        <TextBox x:Name="ActivityTraceTextBox"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Auto"
                                                                 FontFamily="Consolas"
                                                                 TextWrapping="NoWrap"/>
                                                </Grid>
                                        </TabItem>
                                        <TabItem Header="認知コンテキスト">
                                                <Grid Margin="8">
                                                        <TextBox x:Name="CognitiveContextTextBox"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Auto"
                                                                 FontFamily="Consolas"
                                                                 TextWrapping="NoWrap"/>
                                                </Grid>
                                        </TabItem>
                                        <TabItem Header="全データ">
                                                <Grid Margin="8">
                                                        <TextBox x:Name="CycleTraceTextBox"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Auto"
                                                                 FontFamily="Consolas"
                                                                 TextWrapping="NoWrap"/>
                                                </Grid>
                                        </TabItem>
                                </TabControl>
                        </Grid>
                </Grid>

                <Border Grid.Row="2"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,1,0,0"
                        Padding="10,6">
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="inspection API に接続して cycle trace を読み込みます。"/>
                </Border>
        </Grid>
</Window>
