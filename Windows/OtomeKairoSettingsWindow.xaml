<Window x:Class="CocoroConsole.Windows.OtomeKairoSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OtomeKairo設定"
        Width="530"
        Height="430"
        WindowStartupLocation="CenterOwner"
        Icon="/Resource/logo.ico">

    <Window.Resources>
        <!-- GroupBox 共通スタイル -->
        <Style x:Key="SettingsGroupBoxStyle"
               TargetType="GroupBox">
            <Setter Property="BorderBrush"
                    Value="#CCCCCC"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Foreground"
                    Value="#4873CF"/>
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 設定項目 -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,16,16,0">
            <StackPanel>
                <!-- OtomeKairo 接続設定 -->
                <GroupBox Header="OtomeKairo接続設定"
                          Margin="0,0,0,16"
                          Style="{StaticResource SettingsGroupBoxStyle}">
                    <Border Background="White"
                            Padding="10">
                        <StackPanel>
                            <!-- 説明 -->
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#666666"
                                       Margin="0,0,0,10">
                                OtomeKairo サーバーの接続先を指定します。
                                <LineBreak/>
                                HTTPS で起動している OtomeKairo に接続してください。
                            </TextBlock>

                            <!-- 外部利用チェック -->
                            <CheckBox x:Name="UseExternalOtomeKairoCheckBox"
                                      Content="外部の OtomeKairo サーバーを使用する"
                                      Foreground="#FF4873CF"
                                      Margin="0,0,0,8"
                                      Checked="UseExternalOtomeKairoCheckBox_Changed"
                                      Unchecked="UseExternalOtomeKairoCheckBox_Changed"/>

                            <!-- 接続先ホスト -->
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="接続先ホスト:"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         x:Name="OtomeKairoHostTextBox"
                                         Padding="2"
                                         VerticalAlignment="Center"
                                         Width="260"
                                         HorizontalAlignment="Left"
                                         ToolTip="例: 127.0.0.1 / localhost / 192.168.1.50"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </GroupBox>

                <!-- API 認証設定 -->
                <GroupBox Header="API認証設定"
                          Margin="0,0,0,8"
                          Style="{StaticResource SettingsGroupBoxStyle}">
                    <Border Background="White"
                            Padding="10">
                        <StackPanel>
                            <!-- 説明 -->
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#666666"
                                       Margin="0,0,0,10">
                                OtomeKairo の console_access_token を設定します。
                                未発行のときは接続後に自動取得されます。必要なら手動で入力できます。
                            </TextBlock>

                            <!-- Bearer Token -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Access Token:"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         x:Name="BearerTokenTextBox"
                                         Padding="2"
                                         VerticalAlignment="Center"
                                         Width="260"
                                         HorizontalAlignment="Left"
                                         IsEnabled="True"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- ボタン -->
        <Border Grid.Row="1"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="15">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="OK"
                        Width="80"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="OkButton_Click"/>
                <Button Content="キャンセル"
                        Width="80"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"/>
                <Button Content="適用"
                        Width="80"
                        Height="30"
                        Click="ApplyButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
