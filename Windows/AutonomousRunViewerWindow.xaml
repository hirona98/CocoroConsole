<Window x:Class="CocoroConsole.Windows.AutonomousRunViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CocoroAI 自律実行ビューアー"
        Width="1050"
        Height="760"
        WindowStartupLocation="CenterOwner"
        Icon="/Resource/logo.ico">

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="10">
                        <StackPanel Orientation="Horizontal">
                                <Button x:Name="RefreshButton"
                                        Content="一覧を更新"
                                        Width="110"
                                        Height="28"
                                        Margin="0,0,16,0"
                                        Click="RefreshButton_Click"/>
                                <CheckBox x:Name="AutoRefreshCheckBox"
                                          Content="自動更新"
                                          IsChecked="True"
                                          VerticalAlignment="Center"
                                          Margin="0,0,16,0"
                                          Checked="AutoRefreshCheckBox_Changed"
                                          Unchecked="AutoRefreshCheckBox_Changed"/>
                                <TextBlock Text="自律実行の進行状況を表示します。"
                                           VerticalAlignment="Center"
                                           Foreground="#444444"/>
                        </StackPanel>
                </Border>

                <Grid Grid.Row="1"
                      Margin="8">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="260"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#F8FAFC"
                                BorderBrush="#D9E2EF"
                                BorderThickness="1"
                                Padding="8"
                                Margin="0,0,0,8">
                                <TextBlock x:Name="SummaryTextBlock"
                                           Text="件数: 0 / 進行中: 0 / 待機中: 0 / 一時停止: 0 / 完了: 0 / キャンセル: 0"
                                           Foreground="#333333"
                                           TextWrapping="Wrap"/>
                        </Border>

                        <DataGrid x:Name="RunListDataGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  SelectionChanged="RunListDataGrid_SelectionChanged"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  AlternatingRowBackground="#F9F9F9"
                                  RowHeight="24"
                                  ColumnHeaderHeight="26"
                                  MinColumnWidth="70"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                                <DataGrid.Resources>
                                        <Style TargetType="TextBlock">
                                                <Setter Property="TextTrimming"
                                                        Value="CharacterEllipsis"/>
                                                <Setter Property="TextWrapping"
                                                        Value="NoWrap"/>
                                                <Setter Property="VerticalAlignment"
                                                        Value="Center"/>
                                        </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                        <DataGridTextColumn Header="状態"
                                                            Binding="{Binding StatusDisplay, Mode=OneWay}"
                                                            Width="110"/>
                                        <DataGridTextColumn Header="目的（何をするか）"
                                                            Binding="{Binding ObjectiveDisplay, Mode=OneWay}"
                                                            Width="2*"/>
                                        <DataGridTextColumn Header="今の動き"
                                                            Binding="{Binding CurrentStepDisplay, Mode=OneWay}"
                                                            Width="2*"/>
                                        <DataGridTextColumn Header="次の予定"
                                                            Binding="{Binding NextRunAtDisplay, Mode=OneWay}"
                                                            Width="140"/>
                                        <DataGridTextColumn Header="能力待ち"
                                                            Binding="{Binding WaitingRequestIdDisplay, Mode=OneWay}"
                                                            Width="90"/>
                                        <DataGridTextColumn Header="更新"
                                                            Binding="{Binding UpdatedAtDisplay, Mode=OneWay}"
                                                            Width="140"/>
                                        <DataGridTextColumn Header="起点"
                                                            Binding="{Binding OriginKindDisplay, Mode=OneWay}"
                                                            Width="120"/>
                                </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            Margin="0,0,0,6">
                                        <TextBlock x:Name="SelectedRunTitleTextBlock"
                                                   Text="run 未選択"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="SelectedRunMetaTextBlock"
                                                   Text=""
                                                   Foreground="#555555"/>
                                </StackPanel>

                                <TextBox x:Name="SelectedRunDetailsTextBox"
                                         Grid.Row="1"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         TextWrapping="Wrap"/>
                        </Grid>
                </Grid>

                <Border Grid.Row="2"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,1,0,0"
                        Padding="10,6">
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="OtomeKairo API から自律実行 run を表示します。"/>
                </Border>
        </Grid>
</Window>
