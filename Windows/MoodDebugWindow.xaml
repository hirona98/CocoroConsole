<Window x:Class="CocoroConsole.Windows.MoodDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="感情デバッグ"
        Width="800"
        Height="850"
        WindowState="Normal"
        WindowStartupLocation="CenterOwner"
        Icon="/Resource/logo.ico">

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- メイン表示 -->
                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12"
                                    Orientation="Vertical">

                                <!-- 基本情報 -->
                                <GroupBox Header="基本情報"
                                          Margin="0,0,0,10">
                                        <Grid Margin="10">
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="0"
                                                           Text="状態ID:"/>
                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="1"
                                                           Text="{Binding StateId}"/>

                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="0"
                                                           Text="本文:"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="1"
                                                           Text="{Binding BodyText}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="0"
                                                           Text="確信度:"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="1"
                                                           Text="{Binding Confidence}"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Grid.Row="3"
                                                           Grid.Column="0"
                                                           Text="重要度:"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="3"
                                                           Grid.Column="1"
                                                           Text="{Binding Salience}"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Grid.Row="4"
                                                           Grid.Column="0"
                                                           Text="経過秒数:"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="4"
                                                           Grid.Column="1"
                                                           Text="{Binding DtSeconds}"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Grid.Row="5"
                                                           Grid.Column="0"
                                                           Text="最終確認:"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="5"
                                                           Grid.Column="1"
                                                           Text="{Binding LastConfirmedAt}"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Grid.Row="6"
                                                           Grid.Column="0"
                                                           Text="現在時刻:"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="6"
                                                           Grid.Column="1"
                                                           Text="{Binding Now}"
                                                           Margin="0,6,0,0"/>
                                        </Grid>
                                </GroupBox>

                                <!-- VAD -->
                                <GroupBox Header="VAD"
                                          Margin="0,0,0,10">
                                        <Grid Margin="10">
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="0"
                                                           Text="種別"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="1"
                                                           Text="V（快・不快）"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="2"
                                                           Text="A（覚醒・沈静）"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="3"
                                                           Text="D（支配・従属）"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="0"
                                                           Text="基調"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="1"
                                                           Text="{Binding BaselineV}"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="2"
                                                           Text="{Binding BaselineA}"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="3"
                                                           Text="{Binding BaselineD}"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="0"
                                                           Text="衝撃（減衰後）"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="1"
                                                           Text="{Binding ShockV}"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="2"
                                                           Text="{Binding ShockA}"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="3"
                                                           Text="{Binding ShockD}"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Grid.Row="3"
                                                           Grid.Column="0"
                                                           Text="合成（現在）"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="3"
                                                           Grid.Column="1"
                                                           Text="{Binding VadV}"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="3"
                                                           Grid.Column="2"
                                                           Text="{Binding VadA}"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="3"
                                                           Grid.Column="3"
                                                           Text="{Binding VadD}"
                                                           Margin="0,6,0,0"/>
                                        </Grid>
                                </GroupBox>

                                <!-- 瞬間感情（最新1件） -->
                                <GroupBox Header="瞬間感情（最新1件）"
                                          Margin="0,0,0,10">
                                        <Grid Margin="10">
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- 1件の基本情報 -->
                                                <Grid Grid.Row="0"
                                                      Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="160"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="160"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="0"
                                                                   Text="source:"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="1"
                                                                   Text="{Binding LatestAffect.EventSource}"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="2"
                                                                   Text="confidence:"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="3"
                                                                   Text="{Binding LatestAffect.Confidence}"
                                                                   Margin="0,6,0,0"/>

                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="0"
                                                                   Text="event_created_at:"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="1"
                                                                   Text="{Binding LatestAffect.EventCreatedAt}"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="2"
                                                                   Text="affect_created_at:"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="3"
                                                                   Text="{Binding LatestAffect.AffectCreatedAt}"
                                                                   Margin="0,6,0,0"/>

                                                        <TextBlock Grid.Row="2"
                                                                   Grid.Column="0"
                                                                   Text="labels:"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="2"
                                                                   Grid.Column="1"
                                                                   Grid.ColumnSpan="3"
                                                                   Text="{Binding LatestAffect.MomentAffectLabels}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,6,0,0"/>
                                                </Grid>

                                                <!-- VAD（1件） -->
                                                <Grid Grid.Row="1"
                                                      Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="160"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="0"
                                                                   Text="VAD"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="1"
                                                                   Text="V"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="2"
                                                                   Text="A"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="0"
                                                                   Grid.Column="3"
                                                                   Text="D"
                                                                   Margin="0,6,0,0"/>

                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="0"
                                                                   Text="最新"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="1"
                                                                   Text="{Binding LatestAffect.VadV}"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="2"
                                                                   Text="{Binding LatestAffect.VadA}"
                                                                   Margin="0,6,0,0"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="3"
                                                                   Text="{Binding LatestAffect.VadD}"
                                                                   Margin="0,6,0,0"/>
                                                </Grid>

                                                <TextBlock Grid.Row="2"
                                                           Text="本文:"/>
                                                <TextBox Grid.Row="3"
                                                         Text="{Binding LatestAffect.MomentAffectText}"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Height="80"
                                                         Margin="0,4,0,0"/>

                                                <TextBlock Grid.Row="4"
                                                           Text="内心:"
                                                           Margin="0,10,0,0"/>
                                                <TextBox Grid.Row="5"
                                                         Text="{Binding LatestAffect.InnerThoughtText}"
                                                         IsReadOnly="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Height="80"
                                                         Margin="0,4,0,0"/>
                                        </Grid>
                                </GroupBox>
                        </StackPanel>
                </ScrollViewer>

                <!-- ステータス -->
                <Border Grid.Row="1"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,1,0,0"
                        Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusMessage}"/>
                                <TextBlock Text="{Binding LastUpdatedText}"
                                           Margin="20,0,0,0"/>
                        </StackPanel>
                </Border>
        </Grid>
</Window>
