<Window x:Class="CocoroConsole.Windows.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CocoroAI ログビューアー"
        Width="1000"
        Height="1000"
        WindowState="Normal"
        WindowStartupLocation="CenterOwner"
        Icon="/Resource/logo.ico">

        <Window.Resources>
                <Style x:Key="ComponentFilterDropDownButtonStyle"
                       TargetType="ToggleButton">
                        <Setter Property="Background"
                                Value="White"/>
                        <Setter Property="Foreground"
                                Value="#333333"/>
                        <Setter Property="BorderBrush"
                                Value="#B8C4E0"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Padding"
                                Value="8,0"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="ButtonBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="Stretch"
                                                                          VerticalAlignment="Center"
                                                                          Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="ButtonBorder"
                                                                        Property="Background"
                                                                        Value="#F2F6FF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                                <Setter TargetName="ButtonBorder"
                                                                        Property="BorderBrush"
                                                                        Value="#4873CF"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <Style x:Key="CompactFilterCheckBoxStyle"
                       TargetType="CheckBox">
                        <Setter Property="FontSize"
                                Value="12"/>
                        <Setter Property="MinHeight"
                                Value="20"/>
                        <Setter Property="Margin"
                                Value="0,1,6,1"/>
                        <Setter Property="VerticalContentAlignment"
                                Value="Center"/>
                </Style>

                <!-- ログレベル別の色設定 -->
                <Style x:Key="LogLevelCellStyle"
                       TargetType="DataGridCell">
                        <Style.Triggers>
                                <DataTrigger Binding="{Binding level}"
                                             Value="ERROR">
                                        <Setter Property="Foreground"
                                                Value="Red"/>
                                        <Setter Property="FontWeight"
                                                Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding level}"
                                             Value="WARNING">
                                        <Setter Property="Foreground"
                                                Value="Orange"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding level}"
                                             Value="INFO">
                                        <Setter Property="Foreground"
                                                Value="Blue"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding level}"
                                             Value="DEBUG">
                                        <Setter Property="Foreground"
                                                Value="Gray"/>
                                </DataTrigger>
                        </Style.Triggers>
                </Style>

                <!-- セパレーター行のスタイル -->
                <Style x:Key="SeparatorRowStyle"
                       TargetType="DataGridRow">
                        <Style.Triggers>
                                <DataTrigger Binding="{Binding component}"
                                             Value="SEPARATOR">
                                        <Setter Property="Background"
                                                Value="#E8F4FD"/>
                                        <Setter Property="BorderBrush"
                                                Value="#4A90E2"/>
                                        <Setter Property="BorderThickness"
                                                Value="0,1,0,1"/>
                                        <Setter Property="FontWeight"
                                                Value="Bold"/>
                                        <Setter Property="Foreground"
                                                Value="#2C5282"/>
                                </DataTrigger>
                        </Style.Triggers>
                </Style>
        </Window.Resources>

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- フィルターコントロール -->
                <Border Grid.Row="0"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                        <WrapPanel Orientation="Horizontal"
                                   VerticalAlignment="Center">
                                <Label Content="レベル:"
                                       VerticalAlignment="Center"
                                       Padding="0,0,4,0"/>
                                <ComboBox x:Name="LevelFilterComboBox"
                                          Width="120"
                                          Height="25"
                                          Margin="0,0,16,0"
                                          SelectionChanged="LevelFilterComboBox_SelectionChanged">
                                        <ComboBoxItem Content="全て"
                                                      Tag=""/>
                                        <ComboBoxItem Content="INFO以上"
                                                      IsSelected="True"
                                                      Tag="INFO"/>
                                        <ComboBoxItem Content="WARNING以上"
                                                      Tag="WARNING"/>
                                        <ComboBoxItem Content="ERRORのみ"
                                                      Tag="ERROR"/>
                                </ComboBox>

                                <Button x:Name="ClearButton"
                                        Content="クリア"
                                        Width="80"
                                        Height="25"
                                        Margin="0,0,18,0"
                                        Click="ClearButton_Click"/>

                                <CheckBox x:Name="AutoScrollCheckBox"
                                          Content="自動スクロール"
                                          IsChecked="True"
                                          VerticalAlignment="Center"
                                          Margin="0,0,18,0"
                                          Checked="AutoScrollCheckBox_Changed"
                                          Unchecked="AutoScrollCheckBox_Changed"/>

                                <Label Content="コンポーネント:"
                                       VerticalAlignment="Center"
                                       Padding="0,0,4,0"/>
                                <Grid>
                                        <ToggleButton x:Name="ComponentFilterToggleButton"
                                                      Width="180"
                                                      Height="25"
                                                      Style="{StaticResource ComponentFilterDropDownButtonStyle}">
                                                <DockPanel LastChildFill="True">
                                                        <Path DockPanel.Dock="Right"
                                                              Fill="#4873CF"
                                                              Width="8"
                                                              Height="4"
                                                              Stretch="Uniform"
                                                              Margin="8,0,0,0"
                                                              VerticalAlignment="Center"
                                                              Data="M 0 0 L 4 4 L 8 0 Z"/>
                                                        <TextBlock x:Name="ComponentFilterButtonTextBlock"
                                                                   Text="0 / 0 選択"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                </DockPanel>
                                        </ToggleButton>

                                        <Popup x:Name="ComponentFilterPopup"
                                               Placement="Bottom"
                                               PlacementTarget="{Binding ElementName=ComponentFilterToggleButton}"
                                               IsOpen="{Binding IsChecked, ElementName=ComponentFilterToggleButton, Mode=TwoWay}"
                                               StaysOpen="False"
                                               PopupAnimation="Fade">
                                                <Border Background="White"
                                                        BorderBrush="#B8C4E0"
                                                        BorderThickness="1"
                                                        Padding="8"
                                                        MinWidth="260"
                                                        MaxWidth="360">
                                                        <Grid>
                                                                <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                </Grid.RowDefinitions>

                                                                <ScrollViewer Grid.Row="0"
                                                                              Width="310"
                                                                              MaxHeight="220"
                                                                              VerticalScrollBarVisibility="Auto">
                                                                        <ItemsControl x:Name="ComponentFilterItemsControl">
                                                                                <ItemsControl.ItemsPanel>
                                                                                        <ItemsPanelTemplate>
                                                                                                <WrapPanel Orientation="Horizontal"
                                                                                                           ItemWidth="150"/>
                                                                                        </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                                <CheckBox Content="{Binding Component}"
                                                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                          Style="{StaticResource CompactFilterCheckBoxStyle}"
                                                                                                          ToolTip="{Binding Component}"
                                                                                                          Checked="ComponentFilterCheckBox_Changed"
                                                                                                          Unchecked="ComponentFilterCheckBox_Changed"/>
                                                                                        </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                </ScrollViewer>
                                                        </Grid>
                                                </Border>
                                        </Popup>
                                </Grid>
                        </WrapPanel>
                </Border>

                <!-- ログ表示エリア -->
                <DataGrid x:Name="LogDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E0E0E0"
                          AlternatingRowBackground="#F9F9F9"
                          HeadersVisibility="Column"
                          CanUserResizeColumns="True"
                          CanUserReorderColumns="False"
                          CanUserSortColumns="True"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True"
                          RowStyle="{StaticResource SeparatorRowStyle}">

                        <DataGrid.Columns>
                                <!-- タイムスタンプ -->
                                <DataGridTextColumn Header="時刻"
                                                    Binding="{Binding timestamp, StringFormat='HH:mm:ss.fff'}"
                                                    Width="80"
                                                    CanUserResize="False"/>

                                <!-- ログレベル -->
                                <DataGridTextColumn Header="レベル"
                                                    Binding="{Binding level}"
                                                    Width="70"
                                                    CanUserResize="False"
                                                    CellStyle="{StaticResource LogLevelCellStyle}"/>

                                <!-- コンポーネント -->
                                <DataGridTextColumn Header="コンポーネント"
                                                    Binding="{Binding component}"
                                                    Width="120"
                                                    CanUserResize="True"/>

                                <!-- メッセージ（3行に制限） -->
                                <DataGridTemplateColumn Header="メッセージ"
                                                        Width="*"
                                                        ClipboardContentBinding="{Binding message}">
                                        <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                        <TextBlock Text="{Binding message}"
                                                                   TextWrapping="Wrap"
                                                                   MaxHeight="54"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding message}"/>
                                                </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                        </DataGrid.Columns>
                </DataGrid>

                <!-- ステータスバー -->
                <Border Grid.Row="2"
                        Background="#F5F5F5"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,1,0,0"
                        Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="StatusTextBlock"
                                           Text="ログ待機中..."
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="LogCountTextBlock"
                                           Text="総件数: 0"
                                           VerticalAlignment="Center"
                                           Margin="20,0,0,0"/>
                        </StackPanel>
                </Border>
        </Grid>
</Window>
